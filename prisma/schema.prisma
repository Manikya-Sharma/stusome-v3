generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model Account {
  id        Int      @id @default(sequence())
  email     String
  imageUrl  String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
